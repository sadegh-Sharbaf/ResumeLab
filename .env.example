# Local Django settings
DJANGO_SECRET_KEY=change-this-long-random-value
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=0

# Local fallback: leave DATABASE_URL empty to use db.sqlite3.
# PostgreSQL / Neon example:
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Optional locally; required on Render if uploaded avatars must survive deploys.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

SEED_DEMO=1
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120

# Optional on Windows/Linux when Chrome is not auto-detected
CHROME_BIN=
